# dev-mode: tmux development layout
# Usage:
#   dev-mode          → attach to existing session, or create new one
#   dev-mode reload   → kill session and recreate with fresh layout
dev-mode() {
  local session="sandbox"

  if [[ "$1" == "reload" ]]; then
    command tmux kill-session -t "$session" 2>/dev/null
    _dev_mode_create "$session"
    return
  elif command tmux has-session -t "$session" 2>/dev/null; then
    command tmux attach-session -t "$session"
  else
    _dev_mode_create "$session"
  fi
}

_dev_mode_create() {
  local session="$1"
  local claude_cmd="claude --dangerously-skip-permissions"

  # Window 1: claude (3-pane layout, each running claude)
  command tmux new-session -d -s "$session" -n "claude" -x "$(tput cols)" -y "$(tput lines)"
  command tmux split-window -h -t "$session" -p 40
  command tmux split-window -v -t "$session"
  command tmux send-keys -t "$session":1.1 "$claude_cmd" C-m
  command tmux send-keys -t "$session":1.2 "$claude_cmd" C-m
  command tmux send-keys -t "$session":1.3 "$claude_cmd" C-m
  command tmux select-pane -t "$session":1.1

  # Window 2: opencode
  command tmux new-window -t "$session" -n "opencode"
  command tmux send-keys -t "$session":2 "opencode" C-m

  # Window 3: code
  command tmux new-window -t "$session" -n "code"

  # Window 4: github (gh-dash TUI)
  command tmux new-window -t "$session" -n "github"
  command tmux send-keys -t "$session":4 "gh dash" C-m

  # Ensure tmux config + TPM plugins are loaded
  command tmux source-file ~/.tmux.conf

  # Focus first window and attach
  command tmux select-window -t "$session":1
  command tmux attach-session -t "$session"
}

# Paste clipboard image to file and print path
clip() {
  local f="/tmp/clip-$(date +%s).png"
  pngpaste "$f" 2>/dev/null && echo "$f" || echo "No image in clipboard"
}

# Ctrl+V pastes clipboard image path inline
_clip_inline() {
  local f="/tmp/clip-$(date +%s).png"
  if pngpaste "$f" 2>/dev/null; then
    LBUFFER+="$f"
  fi
}
zle -N _clip_inline
bindkey '^X^V' _clip_inline

